            {
              "listen": "prerequest",
              "script": {
                "id": "a301f7c5-2aee-4c4a-803b-e88f9d0216c5",
                "exec": [
                  "if (pm.request.method === \"POST\") {\r",
                  "    // Risolve le variabili ({{dev_url}} ecc.) nell'URL reale\r",
                  "    const fullUrl = pm.variables.replaceIn(pm.request.url.toString());\r",
                  "\r",
                  "    // Taglia dopo lo '0001/' -> service root, che qui rilascia il token\r",
                  "    let rootUrl = fullUrl.split(/[?#]/)[0];\r",
                  "    const m = rootUrl.match(/^(.*\\/0001\\/)/);\r",
                  "    if (m) rootUrl = m[1];\r",
                  "    else rootUrl = rootUrl.replace(/\\/[^\\/]+\\/?$/, \"/\"); // fallback: togli l'entity\r",
                  "\r",
                  "    const authHeader = \"Basic \" + btoa(\r",
                  "        pm.variables.get(\"username\") + \":\" + pm.variables.get(\"password\")\r",
                  "    );\r",
                  "\r",
                  "    pm.sendRequest({\r",
                  "        url: rootUrl,\r",
                  "        method: \"GET\",\r",
                  "        header: {\r",
                  "            \"X-CSRF-Token\": \"Fetch\",\r",
                  "            \"Accept\": \"application/json\",\r",
                  "            \"Authorization\": authHeader\r",
                  "        }\r",
                  "    }, function (err, res) {\r",
                  "        if (err) { console.error(\"Fetch CSRF fallito:\", err); return; }\r",
                  "        const token = res.headers.get(\"x-csrf-token\");\r",
                  "        console.log(\"Fetch \" + rootUrl + \" → \" + res.code + \" | token: \" + (token || \"(vuoto)\"));\r",
                  "        if (token && token.toLowerCase() !== \"required\" && token.toLowerCase() !== \"fetch\") {\r",
                  "            pm.collectionVariables.set(\"csrfToken\", token);\r",
                  "            pm.request.headers.upsert({ key: \"X-CSRF-Token\", value: token });\r",
                  "            console.log(\"✅ Token applicato\");\r",
                  "        }\r",
                  "    });\r",
                  "}"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
